UPLOAD_TOKEN=your-secret-token-here

# Plex library integration
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Audio languages kept in library conversions (ISO 639-2 codes, comma-separated)
LIBRARY_AUDIO_LANGS=eng,spa

# LLM that rewrites multi-version movie filenames into short human labels
VERSION_NAME_LLM_API_KEY=
# Optional model override (default: gpt-5-nano)
VERSION_NAME_LLM_MODEL=
