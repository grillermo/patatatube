#!/bin/bash
# Production: multiple worker processes for higher throughput.
#   WEB_CONCURRENCY=4 ./serve   # override worker count (default 2)
# Development: DEV=1 ./serve     # single process + hot reload (workers ignored)

PORT="${PORT:-3050}"
PYTHON_BIN="${PYTHON_BIN:-python_env/bin/python}"

# macOS launchd hands processes a 256-fd soft limit. Video streaming, HLS
# segment bursts, preview fetches and SQLite each hold fds, so raise the soft
# limit toward the hard cap. Defense in depth on top of closing connections.
ulimit -n "${FD_LIMIT:-8192}" 2>/dev/null || true

if [ "$DEV" = "1" ]; then
  exec "$PYTHON_BIN" -m uvicorn main:app \
    --host 0.0.0.0 \
    --port "$PORT" \
    --reload \
    --reload-dir . \
    --reload-include '*.py' \
    --reload-exclude '.git/*' \
    --reload-exclude '.venv/*' \
    --reload-exclude 'python_env/*' \
    --reload-exclude 'videos/*' \
    --reload-exclude 'assets/splash/*' \
    --proxy-headers \
    --forwarded-allow-ips='*'
fi

exec "$PYTHON_BIN" -m uvicorn main:app \
  --host 0.0.0.0 \
  --port "$PORT" \
  --workers "${WEB_CONCURRENCY:-2}" \
  --proxy-headers \
  --forwarded-allow-ips='*'
