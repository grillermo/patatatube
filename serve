#!/bin/bash
# Production: multiple worker processes for higher throughput.
#   WEB_CONCURRENCY=4 ./serve   # override worker count (default 2)
# Development: DEV=1 ./serve     # single process + hot reload (workers ignored)

# Caddy owns the client-facing :3050 and serves static assets / HLS segments /
# downloaded MP4s from disk (see ~/c/server/Caddyfile); the app sits behind it.
PORT="${PORT:-3051}"
PYTHON_BIN="${PYTHON_BIN:-python_env/bin/python}"

# macOS launchd hands processes a 256-fd soft limit. Video streaming, HLS
# segment bursts, preview fetches and SQLite each hold fds, so raise the soft
# limit toward the hard cap. Defense in depth on top of closing connections.
ulimit -n "${FD_LIMIT:-8192}" 2>/dev/null || true

# Prefix every line with a colored label so interleaved streams are tellable
# apart. $1: ANSI color code, $2: label. awk (not sed) for line buffering.
colorize() {
  awk -v p="$(printf '\033[1;%sm%-7s|\033[0m' "$1" "$2")" '{ print p, $0; fflush() }'
}

if [ "$DEV" = "1" ]; then
  exec > >(colorize 36 dev) 2>&1
  exec "$PYTHON_BIN" -m uvicorn main:app \
    --host 0.0.0.0 \
    --port "$PORT" \
    --reload \
    --reload-dir . \
    --reload-include '*.py' \
    --reload-exclude '.git/*' \
    --reload-exclude '.venv/*' \
    --reload-exclude 'python_env/*' \
    --reload-exclude 'videos/*' \
    --reload-exclude 'assets/splash/*' \
    --proxy-headers \
    --forwarded-allow-ips='*'
fi

# gunicorn manages the worker lifecycle (respawn on crash, graceful reload via
# SIGHUP, staged shutdown); uvicorn workers do the actual ASGI serving.
# Access and error logs get their own colors via process substitution; anything
# workers print directly (stdout/stderr) falls through to the "web" label.
# fd 3 preserves the real stdout so the log labels don't also pick up "web".
exec 3>&1
exec > >(colorize 34 web) 2>&1
exec "$PYTHON_BIN" -m gunicorn main:app \
  --worker-class uvicorn_worker.UvicornWorker \
  --workers "${WEB_CONCURRENCY:-3}" \
  --bind "0.0.0.0:$PORT" \
  --forwarded-allow-ips='*' \
  --access-logfile >(colorize 32 access >&3) \
  --error-logfile >(colorize 33 app >&3)
